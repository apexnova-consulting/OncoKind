# App (for Stripe redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe (set all 4 price IDs from Dashboard → Products)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...                    # Pro monthly (fallback if PRO_MONTHLY not set)
STRIPE_PRICE_ID_PRO_MONTHLY=price_...         # OncoKind Pro — monthly
STRIPE_PRICE_ID_PRO_YEARLY=price_...          # OncoKind Pro — yearly
STRIPE_PRICE_ID_ADVOCATE_MONTHLY=price_...    # Advocate Plan — monthly
STRIPE_PRICE_ID_ENTERPRISE_UNLIMITED=price_... # Enterprise — monthly unlimited users
STRIPE_PRICE_ID_ENTERPRISE_PER_SEAT=price_...  # Enterprise — monthly per seat

# Anthropic (Clarity engine)
ANTHROPIC_API_KEY=sk-ant-...

# Required for patient_reports encryption (32 bytes base64)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=

# Advocacy & Financial Navigation
FINANCIAL_AID_CRON_SECRET=replace-me-with-a-long-random-string
FINANCIAL_AID_SCRAPER_MODE=live
# Optional local/dev override if you want Playwright to use a local Chrome/Chromium binary.
PLAYWRIGHT_EXECUTABLE_PATH=
# Optional custom UA for external funding sites.
FINANCIAL_AID_SCRAPER_USER_AGENT=

# E2E / Playwright
ENABLE_E2E_TEST_ROUTES=0
BASE_URL=http://localhost:3000
TEST_FREE_EMAIL=
TEST_FREE_PASS=
TEST_ADVOCATE_EMAIL=
TEST_ADVOCATE_PASS=
